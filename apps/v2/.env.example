# =============================================================================
# Philippine Community v2 — Environment variables
# =============================================================================
# Copy this file to `.env.local` for local development.
# Required vs Optional is annotated below; missing required vars cause runtime
# errors at startup (validated by lib/env/validate.ts in W2).

# -----------------------------------------------------------------------------
# REQUIRED: Supabase (v2 dedicated project)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# REQUIRED: Facebook OAuth (for login)
# -----------------------------------------------------------------------------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# -----------------------------------------------------------------------------
# REQUIRED: Google Gemini (for AI chat from W4)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# REQUIRED: Sentry (error monitoring)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# REQUIRED: App URL (production = https://app.novalis.ph)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ja

# -----------------------------------------------------------------------------
# REQUIRED: Feature flags
# -----------------------------------------------------------------------------
# Payment system (Komoju). Default: false (free for all users during launch).
# Flip to "true" only after Komoju production approval and ToS revision.
# See tasks/W2-design.md §6-5 for switching checklist.
NEXT_PUBLIC_PAYMENT_ENABLED=false

# -----------------------------------------------------------------------------
# OPTIONAL: Facebook Messenger (for Bot from W7 — reserve now, fill later)
# -----------------------------------------------------------------------------
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=
MESSENGER_APP_SECRET=

# -----------------------------------------------------------------------------
# OPTIONAL: Komoju (only used when NEXT_PUBLIC_PAYMENT_ENABLED=true)
# -----------------------------------------------------------------------------
# Test keys can be safely set ahead of time for development; production keys
# go live with the flag flip.
KOMOJU_PUBLIC_KEY=
KOMOJU_SECRET_KEY=
KOMOJU_WEBHOOK_SECRET=
