# =============================================================================
# Philippine Community v2 — Environment variables
# =============================================================================
# Copy this file to `.env.local` for local development.
# Required vs Optional is annotated below; missing required vars cause runtime
# errors at startup (validated by lib/env/validate.ts in W2).

# -----------------------------------------------------------------------------
# REQUIRED: Supabase (v2 dedicated project)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# REQUIRED: Facebook OAuth (for login)
# -----------------------------------------------------------------------------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# -----------------------------------------------------------------------------
# REQUIRED: Google Gemini (for AI chat from W4)
# GEMINI_MODEL defaults to gemini-2.5-flash; override only for experiments.
# GEMINI_TIMEOUT_MS defaults to 30000 (30s); accepts 1000-120000.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_TIMEOUT_MS=

# -----------------------------------------------------------------------------
# OPTIONAL (MVP): Sentry (error monitoring)
#
# MVP demo runs without Sentry — leave all four blank to skip init.
# Phase 2: when monitoring goes on the critical path (Lesson 25), fill
# all four and Sentry init starts reporting.
#
# NEXT_PUBLIC_SENTRY_DSN is read by the browser SDK; SENTRY_DSN is read by
# the server SDK. Keep both set to the same DSN value.
# SENTRY_AUTH_TOKEN is only needed to upload source maps at build time.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# REQUIRED: App URL (production = https://app.novalis.ph)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ja

# -----------------------------------------------------------------------------
# REQUIRED: Feature flags
# -----------------------------------------------------------------------------
# Payment system (Komoju). Default: false (free for all users during launch).
# Flip to "true" only after Komoju production approval and ToS revision.
# See tasks/W2-design.md §6-5 for switching checklist.
NEXT_PUBLIC_PAYMENT_ENABLED=false

# -----------------------------------------------------------------------------
# OPTIONAL (MVP-E): Contact form (Google Form embed)
# When set, /[locale]/contact embeds the form in an iframe. When unset,
# /contact shows a "preparing" placeholder — beta-safe but not useful.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CONTACT_FORM_URL=

# -----------------------------------------------------------------------------
# OPTIONAL: Facebook Messenger (for Bot from W7 — reserve now, fill later)
# -----------------------------------------------------------------------------
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=
MESSENGER_APP_SECRET=

# -----------------------------------------------------------------------------
# OPTIONAL: Anonymous-user purge (scripts/purge-anon-users.ts, P0-C)
# Retention window in hours for "try without signing in" anon accounts.
# Default 72. Used only by the purge CLI / its scheduled job, not the app.
# -----------------------------------------------------------------------------
ANON_RETENTION_HOURS=72

# -----------------------------------------------------------------------------
# OPTIONAL: Escalation cumulative scoring (P2-L). All have safe defaults.
# Keep ESCALATION_USE_CUMULATIVE_SCORE=false until the cumulative model ships;
# P1-F only records the per-message audit trail. See phase2-escalation-design.md.
# -----------------------------------------------------------------------------
ESCALATION_USE_CUMULATIVE_SCORE=false
ESCALATION_SCORE_THRESHOLD=1.5
ESCALATION_SCORE_DECAY=0.6

# -----------------------------------------------------------------------------
# OPTIONAL: Komoju (only used when NEXT_PUBLIC_PAYMENT_ENABLED=true)
# -----------------------------------------------------------------------------
# Test keys can be safely set ahead of time for development; production keys
# go live with the flag flip.
KOMOJU_PUBLIC_KEY=
KOMOJU_SECRET_KEY=
KOMOJU_WEBHOOK_SECRET=
